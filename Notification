local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local lp = Players.LocalPlayer
local gui = lp:WaitForChild("PlayerGui")

local NOTIF_WIDTH = 340
local NOTIF_HEIGHT = 80
local NOTIF_OVERLAP = 18
local NOTIF_PADDING_R = 20
local NOTIF_PADDING_B = 20
local MAX_NOTIFS = 6

local COLORS = {
    info    = Color3.fromRGB(80,  80,  220),
    success = Color3.fromRGB(50,  200, 100),
    warning = Color3.fromRGB(220, 170, 40),
    error   = Color3.fromRGB(220, 60,  60),
}

if _G.PhantomNotifyGui and _G.PhantomNotifyGui.Parent then
    _G.PhantomNotifyGui:Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "PhantomNotify"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.DisplayOrder = 99
ScreenGui.Parent = gui
_G.PhantomNotifyGui = ScreenGui

local activeNotifs = {}

local function repositionAll()
    for i, data in ipairs(activeNotifs) do
        local targetY = -(NOTIF_PADDING_B + (i - 1) * (NOTIF_HEIGHT - NOTIF_OVERLAP) + NOTIF_HEIGHT)
        local zIndex = MAX_NOTIFS - i + 1
        data.frame.ZIndex = zIndex
        for _, v in ipairs(data.frame:GetDescendants()) do
            if v:IsA("GuiObject") then v.ZIndex = zIndex + 1 end
        end
        TweenService:Create(data.frame, TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
            Position = UDim2.new(1, -(NOTIF_WIDTH + NOTIF_PADDING_R), 1, targetY)
        }):Play()
    end
end

local function removeNotif(data)
    if data.removed then return end
    data.removed = true

    for i, d in ipairs(activeNotifs) do
        if d == data then
            table.remove(activeNotifs, i)
            break
        end
    end

    if data.heartbeat then data.heartbeat:Disconnect() end

    local frame = data.frame
    TweenService:Create(frame, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
        Position = UDim2.new(1, NOTIF_PADDING_R + 20, frame.Position.Y.Scale, frame.Position.Y.Offset),
        BackgroundTransparency = 1,
    }):Play()

    task.delay(0.22, function()
        frame:Destroy()
    end)

    repositionAll()
end

function Notify(title, message, duration, notifType)
    duration = duration or 4
    notifType = notifType or "info"
    local accent = COLORS[notifType] or COLORS.info

    if #activeNotifs >= MAX_NOTIFS then
        removeNotif(activeNotifs[#activeNotifs])
    end

    local startY = -(NOTIF_PADDING_B + NOTIF_HEIGHT)

    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, NOTIF_WIDTH, 0, NOTIF_HEIGHT)
    Frame.Position = UDim2.new(1, NOTIF_PADDING_R + 20, 1, startY)
    Frame.BackgroundColor3 = Color3.fromRGB(10, 10, 14)
    Frame.BorderSizePixel = 0
    Frame.ClipsDescendants = true
    Frame.ZIndex = MAX_NOTIFS
    Frame.Parent = ScreenGui
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 10)

    local Stroke = Instance.new("UIStroke", Frame)
    Stroke.Color = accent
    Stroke.Thickness = 1.2
    Stroke.Transparency = 0.4

    local Grad = Instance.new("UIGradient", Frame)
    Grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(16, 16, 24)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(8, 8, 12)),
    })
    Grad.Rotation = 120

    local AccentBar = Instance.new("Frame")
    AccentBar.Size = UDim2.new(0, 4, 1, -20)
    AccentBar.Position = UDim2.new(0, 10, 0.5, 0)
    AccentBar.AnchorPoint = Vector2.new(0, 0.5)
    AccentBar.BackgroundColor3 = accent
    AccentBar.BorderSizePixel = 0
    AccentBar.ZIndex = MAX_NOTIFS + 1
    AccentBar.Parent = Frame
    Instance.new("UICorner", AccentBar).CornerRadius = UDim.new(1, 0)

    local TitleLbl = Instance.new("TextLabel")
    TitleLbl.Text = title
    TitleLbl.Size = UDim2.new(1, -60, 0, 24)
    TitleLbl.Position = UDim2.new(0, 24, 0, 13)
    TitleLbl.BackgroundTransparency = 1
    TitleLbl.TextColor3 = Color3.fromRGB(220, 220, 255)
    TitleLbl.TextSize = 14
    TitleLbl.Font = Enum.Font.GothamBold
    TitleLbl.TextXAlignment = Enum.TextXAlignment.Left
    TitleLbl.ZIndex = MAX_NOTIFS + 1
    TitleLbl.Parent = Frame

    local MsgLbl = Instance.new("TextLabel")
    MsgLbl.Text = message
    MsgLbl.Size = UDim2.new(1, -60, 0, 22)
    MsgLbl.Position = UDim2.new(0, 24, 0, 38)
    MsgLbl.BackgroundTransparency = 1
    MsgLbl.TextColor3 = Color3.fromRGB(130, 130, 160)
    MsgLbl.TextSize = 12
    MsgLbl.Font = Enum.Font.Gotham
    MsgLbl.TextXAlignment = Enum.TextXAlignment.Left
    MsgLbl.TextTruncate = Enum.TextTruncate.AtEnd
    MsgLbl.ZIndex = MAX_NOTIFS + 1
    MsgLbl.Parent = Frame

    local Badge = Instance.new("TextLabel")
    Badge.Text = notifType:upper()
    Badge.Size = UDim2.new(0, 48, 0, 17)
    Badge.Position = UDim2.new(1, -56, 0, 10)
    Badge.BackgroundColor3 = Color3.fromRGB(20, 20, 32)
    Badge.TextColor3 = accent
    Badge.TextSize = 9
    Badge.Font = Enum.Font.GothamBold
    Badge.BorderSizePixel = 0
    Badge.ZIndex = MAX_NOTIFS + 1
    Badge.Parent = Frame
    Instance.new("UICorner", Badge).CornerRadius = UDim.new(0, 4)

    local BarBg = Instance.new("Frame")
    BarBg.Size = UDim2.new(1, 0, 0, 3)
    BarBg.Position = UDim2.new(0, 0, 1, -3)
    BarBg.BackgroundColor3 = Color3.fromRGB(22, 22, 34)
    BarBg.BorderSizePixel = 0
    BarBg.ZIndex = MAX_NOTIFS + 1
    BarBg.Parent = Frame
    Instance.new("UICorner", BarBg).CornerRadius = UDim.new(0, 1)

    local Bar = Instance.new("Frame")
    Bar.Size = UDim2.new(1, 0, 1, 0)
    Bar.BackgroundColor3 = accent
    Bar.BorderSizePixel = 0
    Bar.ZIndex = MAX_NOTIFS + 2
    Bar.Parent = BarBg

    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Text = "x"
    CloseBtn.Size = UDim2.new(0, 18, 0, 18)
    CloseBtn.Position = UDim2.new(1, -24, 0, 36)
    CloseBtn.BackgroundTransparency = 1
    CloseBtn.TextColor3 = Color3.fromRGB(80, 80, 100)
    CloseBtn.TextSize = 12
    CloseBtn.Font = Enum.Font.GothamBold
    CloseBtn.ZIndex = MAX_NOTIFS + 2
    CloseBtn.Parent = Frame

    local data = { frame = Frame, bar = Bar, removed = false }
    table.insert(activeNotifs, 1, data)
    repositionAll()

    TweenService:Create(Frame, TweenInfo.new(0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(1, -(NOTIF_WIDTH + NOTIF_PADDING_R), 1, startY)
    }):Play()

    local elapsed = 0
    local paused = false

    data.heartbeat = RunService.Heartbeat:Connect(function(dt)
        if data.removed then return end
        if not paused then
            elapsed = elapsed + dt
            local pct = math.clamp(1 - (elapsed / duration), 0, 1)
            Bar.Size = UDim2.new(pct, 0, 1, 0)
            if elapsed >= duration then
                removeNotif(data)
            end
        end
    end)

    Frame.MouseEnter:Connect(function()
        if paused then return end
        paused = true
        TweenService:Create(Frame, TweenInfo.new(0.1), { BackgroundColor3 = Color3.fromRGB(14, 14, 20) }):Play()
    end)

    Frame.MouseLeave:Connect(function()
        if not paused then return end
        paused = false
        TweenService:Create(Frame, TweenInfo.new(0.1), { BackgroundColor3 = Color3.fromRGB(10, 10, 14) }):Play()
    end)

    CloseBtn.MouseButton1Click:Connect(function()
        removeNotif(data)
    end)
end
