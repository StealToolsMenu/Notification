local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

local lp = Players.LocalPlayer
local gui = lp:WaitForChild("PlayerGui")

local c = {
    Background  = Color3.fromRGB(11, 11, 11),
    Border      = Color3.fromRGB(26, 26, 26),
    Text        = Color3.fromRGB(255, 255, 255),
    TextDark    = Color3.fromRGB(93, 93, 93),
    Timer       = Color3.fromRGB(255, 255, 255),
}

local NOTIF_WIDTH  = 220
local NOTIF_HEIGHT = 70
local NOTIF_GAP    = 8
local PAD_R        = 20
local PAD_B        = 20

if _G.PhantomNotifyGui and _G.PhantomNotifyGui.Parent then
    _G.PhantomNotifyGui:Destroy()
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name            = "PhantomNotify"
ScreenGui.ResetOnSpawn    = false
ScreenGui.ZIndexBehavior  = Enum.ZIndexBehavior.Sibling
ScreenGui.DisplayOrder    = 99
ScreenGui.Parent          = gui
_G.PhantomNotifyGui       = ScreenGui

local Container = Instance.new("Frame")
Container.Name                = "NotificationContainer"
Container.BackgroundTransparency = 1
Container.AnchorPoint         = Vector2.new(1, 1)
Container.Position            = UDim2.new(1, -PAD_R, 1, -PAD_B)
Container.Size                = UDim2.new(0, NOTIF_WIDTH, 1, -(PAD_B * 2))
Container.ClipsDescendants    = false
Container.Parent              = ScreenGui

local Layout = Instance.new("UIListLayout")
Layout.SortOrder      = Enum.SortOrder.LayoutOrder
Layout.FillDirection  = Enum.FillDirection.Vertical
Layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
Layout.Padding        = UDim.new(0, NOTIF_GAP)
Layout.Parent         = Container

local notifCount = 0

function Notify(config)
    local title       = config.Title       or "Notification"
    local description = config.Description or ""
    local duration    = config.Duration    or 3
    local icon        = config.Icon        or "rbxassetid://10709775704"

    notifCount = notifCount + 1
    local order = notifCount

    local notification = Instance.new("Frame")
    notification.Name              = "Notification"
    notification.BackgroundColor3  = c.Background
    notification.BorderSizePixel   = 0
    notification.Size              = UDim2.new(1, 0, 0, NOTIF_HEIGHT)
    notification.Position          = UDim2.new(1, NOTIF_WIDTH + 20, 0, 0)
    notification.ClipsDescendants  = true
    notification.LayoutOrder       = order
    notification.Parent            = Container

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = notification

    local stroke = Instance.new("UIStroke")
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Color           = c.Border
    stroke.Thickness       = 1.5
    stroke.Parent          = notification

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Text              = title
    titleLabel.Font              = Enum.Font.GothamBold
    titleLabel.TextSize          = 14
    titleLabel.TextColor3        = c.Text
    titleLabel.TextXAlignment    = Enum.TextXAlignment.Left
    titleLabel.BackgroundTransparency = 1
    titleLabel.Position          = UDim2.new(0, 14, 0, 16)
    titleLabel.Size              = UDim2.new(1, -60, 0, 19)
    titleLabel.Parent            = notification

    local descLabel = Instance.new("TextLabel")
    descLabel.Text               = description
    descLabel.Font               = Enum.Font.Gotham
    descLabel.TextSize           = 13
    descLabel.TextColor3         = c.TextDark
    descLabel.TextXAlignment     = Enum.TextXAlignment.Left
    descLabel.TextTruncate       = Enum.TextTruncate.AtEnd
    descLabel.BackgroundTransparency = 1
    descLabel.Position           = UDim2.new(0, 14, 0, 38)
    descLabel.Size               = UDim2.new(1, -60, 0, 19)
    descLabel.Parent             = notification

    local iconImage = Instance.new("ImageLabel")
    iconImage.BackgroundTransparency = 1
    iconImage.Image              = icon
    iconImage.Position           = UDim2.new(1, -33, 0, 23)
    iconImage.Size               = UDim2.new(0, 19, 0, 19)
    iconImage.Parent             = notification
    Instance.new("UIAspectRatioConstraint").Parent = iconImage

    local timerBar = Instance.new("Frame")
    timerBar.Name             = "Timer"
    timerBar.BackgroundColor3 = c.Timer
    timerBar.BorderSizePixel  = 0
    timerBar.Position         = UDim2.new(0, 0, 1, -3)
    timerBar.Size             = UDim2.new(1, 0, 0, 3)
    timerBar.Parent           = notification
    local timerCorner = Instance.new("UICorner")
    timerCorner.CornerRadius = UDim.new(1, 0)
    timerCorner.Parent = timerBar

    TweenService:Create(notification, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0, 0, 0, 0)
    }):Play()

    local elapsed = 0
    local heartbeat = RunService.Heartbeat:Connect(function(dt)
        elapsed = elapsed + dt
        local pct = math.clamp(1 - (elapsed / duration), 0, 1)
        timerBar.Size = UDim2.new(pct, 0, 0, 3)
    end)

    task.delay(duration, function()
        heartbeat:Disconnect()
        TweenService:Create(notification, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Position = UDim2.new(1, NOTIF_WIDTH + 20, 0, 0)
        }):Play()
        task.wait(0.3)
        notification:Destroy()
    end)
end
